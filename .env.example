# MySQL
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=foodrescue

# Backend - Database
DB_USERNAME=root
DB_PASSWORD=123456

# Backend - JWT (bắt buộc đổi trong production)
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Backend - Mail (Gmail)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Backend - URLs
VERIFICATION_BASE_URL=http://localhost:3000/verify-email
RESET_PASSWORD_BASE_URL=http://localhost:3000/reset-password

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
